---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Co-founder Application - UniversityX"
  description="UniversityX is looking for a Growth & GTM Co-founder to help take AI-first learning infrastructure to Africa, the UK, and the US."
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-[#1A0533] text-white px-6 pt-16 pb-14 relative overflow-hidden mt-5">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-[#BB39B4]/10 pointer-events-none"></div>
    <div class="max-w-2xl mx-auto relative z-10">
      <div class="inline-block text-[11px] font-semibold tracking-widest uppercase text-[#D4A853] border border-[#D4A853]/40 px-4 py-1.5 rounded-sm mb-8">
        Open role &middot; Equity-based
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold leading-[1.1] tracking-tight mb-5">
        We're looking for a<br>
        <span class="italic font-extrabold text-[#D4A853]">Growth &amp; GTM</span><br>
        Co-founder
      </h1>
      <p class="text-white/70 text-base md:text-lg leading-relaxed max-w-xl mb-10">
        UniversityX is building AI-first learning infrastructure for African professionals and institutions, and we're expanding into the UK and US. Everyone who has seen the product loves it. Now we need the person who takes it to the world.
      </p>
      <div class="flex flex-wrap gap-8 border-t border-white/10 pt-7">
        <div class="flex flex-col">
          <span class="text-2xl font-bold text-white leading-none">AI-first</span>
          <span class="text-xs text-white/50 mt-1 tracking-wide">Learning platform</span>
        </div>
        <div class="flex flex-col">
          <span class="text-2xl font-bold text-white leading-none">Africa to UK/US</span>
          <span class="text-xs text-white/50 mt-1 tracking-wide">Expansion path</span>
        </div>
        <div class="flex flex-col">
          <span class="text-2xl font-bold text-white leading-none">Equity</span>
          <span class="text-xs text-white/50 mt-1 tracking-wide">Co-founder role</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Form area -->
  <div class="bg-[#FBF8F1] min-h-screen">
    <div class="max-w-2xl mx-auto px-6 py-16">

      <!-- Note box -->
      <div class="bg-[#D4A853]/10 border-l-4 border-[#D4A853] rounded-r-lg px-5 py-4 text-sm text-[#8a6318] leading-relaxed mb-12">
        This is not a job application. We're looking for a co-founder, someone who wants to build this, not just work in it. If that's not you but you know who it is, please send this form to them.
      </div>

      <form
        id="appForm"
        name="cofounder-application"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-0"
      >
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" type="text" /></label>
        </p>
        <input type="hidden" name="form-name" value="cofounder-application" />

        <!-- Section 1: The basics -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">01. The basics</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
            <div>
              <label for="full-name" class="block text-sm font-semibold text-[#1A0533] mb-2">Full name</label>
              <input type="text" id="full-name" name="Full Name" placeholder="Your name" required
                class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
            </div>
            <div>
              <label for="location" class="block text-sm font-semibold text-[#1A0533] mb-2">Location</label>
              <input type="text" id="location" name="Location" placeholder="City, Country"
                class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
            </div>
          </div>

          <div class="mb-5">
            <label for="email" class="block text-sm font-semibold text-[#1A0533] mb-2">Email address</label>
            <input type="email" id="email" name="Email" placeholder="you@example.com" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div class="mb-5">
            <label for="linkedin" class="block text-sm font-semibold text-[#1A0533] mb-2">LinkedIn profile URL</label>
            <input type="url" id="linkedin" name="LinkedIn" placeholder="https://linkedin.com/in/..."
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div class="mb-5">
            <label for="current-role" class="block text-sm font-semibold text-[#1A0533] mb-2">
              Current role <span class="font-normal text-gray-400 text-xs ml-1">if any</span>
            </label>
            <input type="text" id="current-role" name="Current Role" placeholder="e.g. BD Manager at TechCorp, or Freelance"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div>
            <label for="one-liner" class="block text-sm font-semibold text-[#1A0533] mb-2">In one sentence, why UniversityX, why now, why you?</label>
            <textarea id="one-liner" name="One Sentence Pitch" placeholder="Make it honest, not impressive..." rows="3" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>
        </div>

        <hr class="border-gray-200 mb-14" />

        <!-- Section 2: Your hunger -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">02. Your hunger</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label for="resourcefulness" class="block text-sm font-semibold text-[#1A0533] mb-2">What's the most resourceful thing you've done to make something happen with little to no resources?</label>
            <textarea id="resourcefulness" name="Resourcefulness" placeholder="A real story, not a polished one..." rows="4" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div>
            <label for="door-story" class="block text-sm font-semibold text-[#1A0533] mb-2">Describe a time you opened a door that wasn't open for you.</label>
            <textarea id="door-story" name="Door Opening Story" placeholder="Who was on the other side? What happened next?" rows="4"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>
        </div>

        <hr class="border-gray-200 mb-14" />

        <!-- Section 3: Edtech & market sense -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">03. Edtech and market sense</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label for="edtech-pov" class="block text-sm font-semibold text-[#1A0533] mb-2">What do you think is broken about education in Africa? How does UniversityX fix it?</label>
            <textarea id="edtech-pov" name="Edtech POV" placeholder="Your honest perspective..." rows="4" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div>
            <label for="edtech-admiration" class="block text-sm font-semibold text-[#1A0533] mb-2">What's one edtech company globally doing something right, and why?</label>
            <textarea id="edtech-admiration" name="Edtech Admiration" placeholder="Could be big or small, local or global..." rows="3"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>
        </div>

        <hr class="border-gray-200 mb-14" />

        <!-- Section 4: Networks & BD -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">04. Networks and BD</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label for="network-doors" class="block text-sm font-semibold text-[#1A0533] mb-2">
              Name 3 people, companies, or institutions you could bring to the table within 60 days.
              <span class="font-normal text-gray-400 text-xs block mt-0.5">No commitment, just shows range.</span>
            </label>
            <textarea id="network-doors" name="Network Doors" placeholder="e.g. I know the L&D head at X, have a contact at Y university, worked with Z organisation..." rows="4"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold text-[#1A0533] mb-3">Do you have connections in the UK or US education, corporate, or tech space?</label>
            <div class="flex flex-wrap gap-3">
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="UK/US Network" value="Yes, strong connections" class="accent-[#D4A853]" /> Yes, strong
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="UK/US Network" value="A few connections" class="accent-[#D4A853]" /> A few
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="UK/US Network" value="Not yet" class="accent-[#D4A853]" /> Not yet
              </label>
            </div>
          </div>
        </div>

        <hr class="border-gray-200 mb-14" />

        <!-- Section 5: Content & presence -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">05. Content and presence</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label for="content-link" class="block text-sm font-semibold text-[#1A0533] mb-2">
              Are you comfortable on camera? Drop a link to any video, reel, pitch, or content you've made.
              <span class="font-normal text-gray-400 text-xs block mt-0.5">Doesn't have to be professional.</span>
            </label>
            <input type="url" id="content-link" name="Content Link" placeholder="https://..."
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
            <p class="text-xs text-gray-400 mt-2">YouTube, Instagram, LinkedIn video, TikTok, anything that shows you in front of a camera or creating content.</p>
          </div>

          <div class="mb-5">
            <label for="ai-tools" class="block text-sm font-semibold text-[#1A0533] mb-2">Have you used AI tools for content creation?</label>
            <input type="text" id="ai-tools" name="AI Tools Used" placeholder="e.g. Runway, HeyGen, CapCut AI, ElevenLabs..."
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-[#1A0533] mb-3">Your video editing and content creation level</label>
            <div class="flex flex-wrap gap-3">
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Content Level" value="Beginner" class="accent-[#D4A853]" /> Beginner
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Content Level" value="Intermediate" class="accent-[#D4A853]" /> Intermediate
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Content Level" value="Advanced" class="accent-[#D4A853]" /> Advanced
              </label>
            </div>
          </div>
        </div>

        <hr class="border-gray-200 mb-14" />

        <!-- Section 6: The co-founder conversation -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">06. The co-founder conversation</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label class="block text-sm font-semibold text-[#1A0533] mb-3">This is equity-first with a lean early salary. Are you at a life stage where that works for you?</label>
            <div class="flex flex-col gap-3">
              <label class="radio-pill flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Equity Readiness" value="Yes, fully" class="accent-[#D4A853] shrink-0" />
                Yes, fully. I can operate without a big salary right now.
              </label>
              <label class="radio-pill flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Equity Readiness" value="Partly" class="accent-[#D4A853] shrink-0" />
                Partly. I need some base but equity is the real draw.
              </label>
              <label class="radio-pill flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Equity Readiness" value="Need to discuss" class="accent-[#D4A853] shrink-0" />
                I need to discuss the specifics.
              </label>
            </div>
          </div>

          <div class="mb-5">
            <label for="cofounder-vision" class="block text-sm font-semibold text-[#1A0533] mb-2">What does a great co-founder relationship look like to you?</label>
            <textarea id="cofounder-vision" name="Cofounder Vision" rows="4" placeholder="Be honest. What do you need and what do you bring..."
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div class="mb-5">
            <label for="deal-breakers" class="block text-sm font-semibold text-[#1A0533] mb-2">What would make you walk away from a co-founder partnership?</label>
            <textarea id="deal-breakers" name="Deal Breakers" rows="3" placeholder="Red lines you won't cross..."
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold text-[#1A0533] mb-3">Availability</label>
            <div class="flex flex-wrap gap-3">
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Availability" value="Full-time" class="accent-[#D4A853]" /> Full-time
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Availability" value="Part-time to start" class="accent-[#D4A853]" /> Part-time to start
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="Availability" value="Open to discuss" class="accent-[#D4A853]" /> Open to discuss
              </label>
            </div>
          </div>
        </div>

        <hr class="border-gray-200 mb-14" />

        <!-- Submit -->
        <div class="pt-2">
          <button type="submit"
            class="w-full bg-[#BB39B4] hover:bg-[#a030a0] text-white font-bold text-base rounded-full py-4 transition-colors duration-200 cursor-pointer">
            Submit application
          </button>
          <p class="text-xs text-gray-400 text-center mt-4 leading-relaxed">
            Applications are reviewed personally by the CEO. Every submission gets a response within 7 days. Your information is used only for this co-founder search.
          </p>
        </div>
      </form>

      <!-- Success state -->
      <div id="successState" class="hidden text-center py-20">
        <div class="w-14 h-14 bg-[#BB39B4] rounded-full flex items-center justify-center mx-auto mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <h2 class="text-3xl font-extrabold text-[#1A0533] mb-3">Application received.</h2>
        <p class="text-gray-500 text-base max-w-sm mx-auto">Thanks for completing this appllication. You'll hear back within 7 days.</p>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('appForm') as HTMLFormElement | null;
  const successState = document.getElementById('successState');

  // Highlight selected radio options
  document.querySelectorAll('.radio-pill input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      const name = (radio as HTMLInputElement).name;
      document.querySelectorAll(`.radio-pill input[name="${name}"]`).forEach((r) => {
        const label = r.closest('.radio-pill');
        if (label) {
          label.classList.remove('border-[#D4A853]', 'bg-[#D4A853]/10');
          label.classList.add('border-gray-200');
        }
      });
      const selectedLabel = radio.closest('.radio-pill');
      if (selectedLabel) {
        selectedLabel.classList.remove('border-gray-200');
        selectedLabel.classList.add('border-[#D4A853]', 'bg-[#D4A853]/10');
      }
    });
  });

  // Handle Netlify form submission with success state
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(formData as any).toString(),
        });
        form.classList.add('hidden');
        if (successState) successState.classList.remove('hidden');
        window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
      } catch {
        alert('Something went wrong. Please try again or email us directly.');
      }
    });
  }
</script>
