---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Co-founder Application - UniversityX"
  description="UniversityX is looking for a Growth & GTM Co-founder to help take AI-first learning infrastructure to Africa, the UK, and the US."
>
  <Navbar />

  <!-- Hero -->
  <section class="bg-[#1A0533] text-white px-6 pt-16 pb-14 relative overflow-hidden mt-5">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-[#BB39B4]/10 pointer-events-none"></div>
    <div class="max-w-2xl mx-auto relative z-10">
      <div class="inline-block text-[11px] font-semibold tracking-widest uppercase text-[#D4A853] border border-[#D4A853]/40 px-4 py-1.5 rounded-sm mb-8">
        Co-founder role &middot; Equity-based
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold leading-[1.1] tracking-tight mb-5">
        We're looking for a<br>
        <span class="italic font-extrabold text-[#D4A853]">Chief Growth Officer</span><br>
        Co-founder
      </h1>
      <p class="text-white/70 text-base md:text-lg leading-relaxed max-w-xl mb-10">
        UniversityX is building AI-first learning infrastructure for African professionals and institutions. We need a CGO Co-founder who understands how people learn online, knows how to bring great creators to the platform, and can build the commercial engine that takes us from product to market. If that's you, or you know who that is, send this to them.
      </p>
      <div class="flex flex-wrap gap-8 border-t border-white/10 pt-7">
        <div class="flex flex-col">
          <span class="text-2xl font-bold text-white leading-none">AI-first</span>
          <span class="text-xs text-white/50 mt-1 tracking-wide">Learning platform</span>
        </div>
        <div class="flex flex-col">
          <span class="text-2xl font-bold text-white leading-none">Africa to UK/US</span>
          <span class="text-xs text-white/50 mt-1 tracking-wide">Expansion path</span>
        </div>
        <div class="flex flex-col">
          <span class="text-2xl font-bold text-white leading-none">Equity</span>
          <span class="text-xs text-white/50 mt-1 tracking-wide">Co-founder role</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Form area -->
  <div class="bg-[#FBF8F1] min-h-screen">
    <div class="max-w-2xl mx-auto px-6 py-16">

      <!-- Note box -->
      <div class="bg-[#D4A853]/10 border-l-4 border-[#D4A853] rounded-r-lg px-5 py-4 text-sm text-[#8a6318] leading-relaxed mb-12">
        This is not a job application. We're looking for a Chief Growth Officer Co-founder, someone who wants to build this, not just work in it. If that's not you but you know who it is, please send this form to them.
      </div>

      <form
        id="appForm"
        class="space-y-0"
      >

        <!-- Section 1: The basics -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">01. The basics</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
            <div>
              <label for="full-name" class="block text-sm font-semibold text-[#1A0533] mb-2">Full name</label>
              <input type="text" id="full-name" name="full_name" placeholder="Your name" required
                class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
            </div>
            <div>
              <label for="location" class="block text-sm font-semibold text-[#1A0533] mb-2">Location</label>
              <input type="text" id="location" name="location" placeholder="City, Country" required
                class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
            </div>
          </div>

          <div class="mb-5">
            <label for="email" class="block text-sm font-semibold text-[#1A0533] mb-2">Email address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div class="mb-5">
            <label for="linkedin" class="block text-sm font-semibold text-[#1A0533] mb-2">LinkedIn profile URL</label>
            <input type="url" id="linkedin" name="linkedin" placeholder="https://linkedin.com/in/..." required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div class="mb-5">
            <label for="current-role" class="block text-sm font-semibold text-[#1A0533] mb-2">
              Current role <span class="font-normal text-gray-400 text-xs ml-1">if any</span>
            </label>
            <input type="text" id="current-role" name="current_role" placeholder="e.g. BD Manager at TechCorp, or Freelance" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow" />
          </div>

          <div>
            <label for="one-liner" class="block text-sm font-semibold text-[#1A0533] mb-2">In one sentence, why UniversityX, why now, why you?</label>
            <textarea id="one-liner" name="one_sentence_pitch" placeholder="Make it honest, not impressive..." rows="3" required
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>
        </div>  

        <!-- Section 2: Your growth DNA -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">02. Your growth DNA</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label for="creative-growth" class="block text-sm font-semibold text-[#1A0533] mb-2">Describe the most creative way you've ever grown something, an audience, a community, a product, a revenue line. What was the result?</label>
            <textarea id="creative-growth" name="creative_growth_story" placeholder="A real story, not a polished one..." rows="4"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div>
            <label for="zero-budget-growth" class="block text-sm font-semibold text-[#1A0533] mb-2">Have you ever built a marketing or growth strategy from scratch with little to no budget? What did you do?</label>
            <textarea id="zero-budget-growth" name="zero_budget_growth" placeholder="Be specific..." rows="4"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>
        </div>

        <!-- Section 3: Creator Economy & Commercial Instinct -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">03. Creator Economy & Commercial Instinct </span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label for="own-course" class="block text-sm font-semibold text-[#1A0533] mb-2">Have you ever built, designed, or taught an online course yourself? Tell us about it.</label>
            <textarea id="own-course" name="own_course_experience" placeholder="What was it, who was it for, what happened..." rows="4"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div class="mb-5">
            <label for="b2b-deal" class="block text-sm font-semibold text-[#1A0533] mb-2">Have you ever closed a B2B deal or partnership, even informally? What was it and how did you do it?</label>
            <textarea id="b2b-deal" name="b2b_deal_story" placeholder="Walk us through the deal..." rows="4"
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>
        </div>

        <!-- Section 4: The co-founder conversation -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold tracking-widest uppercase text-[#D4A853]">04. The co-founder conversation</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="mb-5">
            <label class="block text-sm font-semibold text-[#1A0533] mb-3">This is equity-first with a lean early salary. Are you at a life stage where that works for you?</label>
            <div class="flex flex-col gap-3">
              <label class="radio-pill flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="equity_readiness" value="Yes, fully" class="accent-[#D4A853] shrink-0" />
                Yes, fully. I can operate without a big salary right now.
              </label>
              <label class="radio-pill flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="equity_readiness" value="Partly" class="accent-[#D4A853] shrink-0" />
                Partly. I need some base but equity is the real draw.
              </label>
              <label class="radio-pill flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="equity_readiness" value="Need to discuss" class="accent-[#D4A853] shrink-0" />
                I need to discuss the specifics.
              </label>
            </div>
          </div>

          <div class="mb-5">
            <label for="cofounder-vision" class="block text-sm font-semibold text-[#1A0533] mb-2">What does a great co-founder relationship look like to you?</label>
            <textarea id="cofounder-vision" name="cofounder_vision" rows="4" placeholder="Be honest. What do you need and what do you bring..."
              class="w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#D4A853] transition-shadow resize-y"></textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold text-[#1A0533] mb-3">Availability</label>
            <div class="flex flex-wrap gap-3">
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="availability" value="Full-time" class="accent-[#D4A853]" /> Full-time
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="availability" value="Part-time to start" class="accent-[#D4A853]" /> Part-time to start
              </label>
              <label class="radio-pill flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl cursor-pointer text-sm text-gray-700 hover:border-[#D4A853] hover:bg-[#D4A853]/5 transition-colors">
                <input type="radio" name="availability" value="Open to discuss" class="accent-[#D4A853]" /> Open to discuss
              </label>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="pt-2">
          <button type="submit"
            class="w-full bg-[#BB39B4] hover:bg-[#a030a0] text-white font-bold text-base rounded-full py-4 transition-colors duration-200 cursor-pointer">
            Submit application
          </button>
          <p class="text-xs text-gray-400 text-center mt-4 leading-relaxed">
            Applications are reviewed personally by the CEO. Every submission gets a response within 7 days. Your information is used only for this co-founder search.
          </p>
        </div>
      </form>

      <!-- Success state -->
      <div id="successState" class="hidden text-center py-20">
        <div class="w-14 h-14 bg-[#BB39B4] rounded-full flex items-center justify-center mx-auto mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <h2 class="text-3xl font-extrabold text-[#1A0533] mb-3">Application received.</h2>
        <p class="text-gray-500 text-base max-w-sm mx-auto">Thanks for completing this appllication. You'll hear back within 7 days.</p>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<script>
  import PocketBase from 'pocketbase';

  declare global {
    interface Window { posthog?: any; }
  }

  const form = document.getElementById('appForm') as HTMLFormElement | null;
  const successState = document.getElementById('successState');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  // Highlight selected radio options
  document.querySelectorAll('.radio-pill input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      const name = (radio as HTMLInputElement).name;
      document.querySelectorAll(`.radio-pill input[name="${name}"]`).forEach((r) => {
        const label = r.closest('.radio-pill');
        if (label) {
          label.classList.remove('border-[#D4A853]', 'bg-[#D4A853]/10');
          label.classList.add('border-gray-200');
        }
      });
      const selectedLabel = radio.closest('.radio-pill');
      if (selectedLabel) {
        selectedLabel.classList.remove('border-gray-200');
        selectedLabel.classList.add('border-[#D4A853]', 'bg-[#D4A853]/10');
      }
    });
  });

  if (form) {
    const pb = new PocketBase(import.meta.env.PUBLIC_POCKETBASE_URL);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Submitting...'; }

      const formData = new FormData(form);

      const data = {
        full_name: formData.get('full_name') as string,
        location: formData.get('location') as string,
        email: formData.get('email') as string,
        linkedin: formData.get('linkedin') as string,
        current_role: formData.get('current_role') as string,
        one_sentence_pitch: formData.get('one_sentence_pitch') as string,
        creative_growth_story: (formData.get('creative_growth_story') as string) || '',
        zero_budget_growth: (formData.get('zero_budget_growth') as string) || '',
        own_course_experience: (formData.get('own_course_experience') as string) || '',
        b2b_deal_story: (formData.get('b2b_deal_story') as string) || '',
        equity_readiness: (formData.get('equity_readiness') as string) || '',
        cofounder_vision: (formData.get('cofounder_vision') as string) || '',
        availability: (formData.get('availability') as string) || '',
      };

      try {
        await pb.collection('Cofounder_Applications').create(data);

        window.posthog?.capture('cofounder_application_submitted', {
          form_name: 'cofounder-application',
        });

        form.classList.add('hidden');
        if (successState) successState.classList.remove('hidden');
        window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
      } catch {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit application'; }
        alert('Something went wrong. Please try again or email us directly.');
      }
    });
  }
</script>
