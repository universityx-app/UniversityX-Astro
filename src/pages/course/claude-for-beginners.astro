---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const course = {
  title: 'Claude for Beginners',
  description: 'Learn to use Claude and other LLMs to work smarter, write better, think clearer, and get more done. No technical background required.',
  price: 0,
  originalPrice: '',
  // startDate: 'Start anytime',
  duration: 'Self Paced',
  level: 'Beginner',
  format: 'Self Paced',
  rating: 4.9,
  thumbnail: '/images/claude-for-beginners.png',
};
---

<Layout
  title="Claude for Beginners - UniversityX"
  description="A free, self-paced course by Anthropic Academy. Learn to use Claude and other LLMs to work smarter, write better, and get more done. No technical skills needed."
>
  <!-- Navbar -->
  <Navbar />

  <main class="bg-white">

    <!-- ── HERO SECTION ─────────────────────────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24 pt-10 pb-0">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <a href="/#browse-courses" class="hover:text-[#BB39B4] transition-colors">All Courses</a>
        <svg class="w-3.5 h-3.5 text-[#BB39B4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6" />
        </svg>
        <span class="text-[#1A0533] font-medium">Claude for Beginners</span>
      </nav>

      <!-- Two-column layout: content left, sidebar right -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-12 xl:gap-16 items-start">

        <!-- ── LEFT COLUMN ───────────────────────────────────────────── -->
        <div>
          <!-- Title -->
          <h1 class="text-3xl md:text-4xl font-extrabold text-[#1A0533] leading-tight mb-5">
            Claude for Beginners
            <em class="font-['Playfair_Display',serif] font-bold">- A Practical Handbook for Beginners on Leveraging LLMs for Everyday Tasks.</em>
          </h1>

          <!-- Description -->
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Most people use AI the same way they used Google, typing a quick question and hoping for the best.
            This course teaches you a better way. You will learn how to have real conversations with Claude,
            give it context that matters, and turn it into a tool that actually fits the way you think and work.
          </p>

          <!-- What you'll learn -->
          <ul class="space-y-2.5 mb-8 text-lg">
            {[
              'How to write effective prompts that get useful, accurate results from Claude every time',
              'How to use Claude as a thinking partner for research, writing, and decision-making',
              'Practical workflows to automate repetitive tasks and save hours every week',
              'How to apply LLMs confidently across work, learning, and personal projects',
            ].map((item) => (
              <li class="flex items-start gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#BB39B4] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <!-- Metadata chips -->
          <div class="flex flex-wrap gap-3 mb-8">
            {[
              { label: '⏱️ Self Paced' },
              { label: '🌱 Beginner' },
              { label: '👥 500+ Enrolled' },
            ].map(({ label }) => (
              <span class="inline-flex items-center gap-2 bg-[#F5F2EB] text-[#1A0533] text-base font-medium px-4 py-2 rounded-full">
                {label}
              </span>
            ))}
          </div>

          <!-- Instructor strip -->
          <div class="border-t border-gray-100 pt-6">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Instructor</p>
            <div class="flex items-center gap-4">
              <img
                src="/images/anthropic-logo.png"
                alt="Babatunde Durotoye"
                class="w-18 h-18 rounded-full object-cover object-top shrink-0"
                loading="eager"
              />
              <div>
                <p class="font-semibold text-[#1A0533] text-lg">Anthropic Academy</p>
                <p class="text-base text-gray-500">The official learning team behind Claude, building courses that make AI accessible to everyone.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ── RIGHT COLUMN: STICKY SIDEBAR ─────────────────────────── -->
        <aside class="lg:sticky lg:top-6">
          <div class="rounded-2xl border border-gray-200 shadow-lg overflow-hidden">
            <!-- Course thumbnail -->
            <img
              src={course.thumbnail}
              alt="Claude for Beginners"
              class="w-full aspect-video object-cover"
              loading="eager"
            />

            <!-- Pricing & CTA -->
            <div class="p-6 space-y-4">
              <!-- Price -->
              <div class="flex items-baseline gap-3">
                <span class="text-3xl font-extrabold text-[#1A0533]">
                  {course.price ? `₦${course.price.toLocaleString()}` : 'FREE'}
                </span>
                {course.originalPrice && (
                  <span class="text-lg text-gray-400 line-through">
                    ₦{course.originalPrice.toLocaleString()}
                  </span>
                )}
              </div>

              <!-- Start date -->
              <!-- <div class="flex items-center gap-2 text-lg text-gray-600">
                <svg class="w-6 h-6 text-[#BB39B4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                {course.startDate}
              </div> -->

              <!-- Countdown Timer -->
              <div class="mt-8 text-center bg-[#F5F2EB] rounded-xl p-4 border border-[#F5F2EB]/80">
                <p class="text-sm font-bold text-[#BB39B4] uppercase tracking-wider mb-2">Course Goes Live In</p>
                <div class="flex items-center justify-center gap-3 countdown-container">
                  <div class="flex flex-col">
                    <span class="text-3xl font-extrabold text-[#1A0533] hours-val">00</span>
                    <span class="text-sm text-gray-500 uppercase tracking-widest mt-0.5">Hrs</span>
                  </div>
                  <span class="text-xl font-bold text-[#1A0533]/30 pb-2">:</span>
                  <div class="flex flex-col">
                    <span class="text-3xl font-extrabold text-[#1A0533] minutes-val">00</span>
                    <span class="text-sm text-gray-500 uppercase tracking-widest mt-0.5">Min</span>
                  </div>
                  <span class="text-xl font-bold text-[#1A0533]/30 pb-2">:</span>
                  <div class="flex flex-col">
                    <span class="text-3xl font-extrabold text-[#1A0533] seconds-val">00</span>
                    <span class="text-sm text-gray-500 uppercase tracking-widest mt-0.5">Sec</span>
                  </div>
                </div>
              </div>

              <!-- Enroll CTA -->
              <a
                id="enroll"
                href="#enroll-form"
                class="block w-full text-center bg-[#BB39B4] hover:bg-[#a832a1] text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200 text-base mt-4"
              >
                Access the Course
              </a>

              <!-- UniversityX Approved -->
              <!-- <div class="flex items-start gap-3 bg-[#F5F2EB] rounded-xl p-4 mt-2">
                <img src="/images/universityx-svg.svg" alt="" class="h-6 w-auto shrink-0 mt-0.5" loading="lazy" />
                <div>
                  <p class="text-sm font-semibold text-[#1A0533]">UniversityX Approved</p>
                  <p class="text-xs text-gray-500 mt-0.5 leading-snug">Reviewed for quality, relevance, and real-world impact.</p>
                </div>
              </div> -->
            </div>
          </div>
        </aside>

      </div>
    </section>


    <!-- ── COURSE OVERVIEW ───────────────────────────────────────────── -->
    <section class="bg-[#F5F2EB] mt-16 py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24 max-w-3xl">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3">Course Overview</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] leading-tight mb-6">
          AI is already changing how people work. This is where you start.
        </h2>
        <div class="space-y-4 text-gray-700 leading-relaxed text-lg md:text-lg">
          <p>
            Claude is one of the most capable AI assistants in the world, but most people are only using
            10% of what it can do. The difference between a frustrating AI experience and a genuinely useful
            one comes down to how you communicate. This course teaches you exactly that: how to ask better
            questions, give better context, and structure conversations that produce results you can actually use.
          </p>
          <p>
            Whether you are a student, a professional, a creative, or just someone who wants to get more done
            in less time, this handbook meets you where you are. No code, no jargon, no prerequisite knowledge
            required. Just practical skills you can apply the moment you finish each lesson.
          </p>
        </div>
      </div>
    </section>


    <!-- ── WHO THIS IS FOR ───────────────────────────────────────────── -->
    <section class="py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3 text-center">Who This Is For</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] text-center mb-12">This Course Is For You If...</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              num: '01',
              title: "You're brand new to AI tools",
              body: "You've heard the buzz but haven't known where to start. This course gives you a clear, structured entry point; no prior experience needed, no jargon to wade through.",
            },
            {
              num: '02',
              title: "You use AI occasionally but want more",
              body: "You've tried ChatGPT or Claude a few times but the results feel hit-or-miss. You want to unlock what these tools can actually do when used intentionally.",
            },
            {
              num: '03',
              title: "You have real work you want AI to help with",
              body: "Writing, research, summarising, planning, brainstorming. You have actual tasks and you want to build repeatable AI-powered workflows around them.",
            },
          ].map(({ num, title, body }) => (
            <div class="bg-[#F5F2EB] rounded-2xl p-7">
              <span class="inline-block text-[#BB39B4] text-sm font-bold bg-white rounded-full px-3 py-1 mb-4">{num}</span>
              <h3 class="text-lg font-bold text-[#1A0533] mb-2 leading-snug">{title}</h3>
              <p class="text-lg text-gray-500 leading-relaxed">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── WHAT'S INCLUDED ───────────────────────────────────────────── -->
    <section class="bg-[#F5F2EB] py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3">What's Included</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] mb-10">Everything you need to succeed</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              title: 'Learn at your own pace',
              body: 'All lessons are available the moment you enroll. No schedule, no deadlines. Go as fast or as slow as you need to.',
              emoji: '⏳',
            },
            {
              title: 'Hands-on exercises',
              body: 'Every module includes real prompts, practical challenges, and scenarios drawn from actual use cases, so you learn by doing, not just reading.',
              emoji: '🛠️',
            },
            {
              title: 'Certificate of completion',
              body: 'Finish the course and earn a shareable certificate. Add it to your LinkedIn, CV, or portfolio to show you know how to work with AI.',
              emoji: '📜',
            },
          ].map(({ title, body, emoji }) => (
            <div class="flex items-start gap-4 bg-white rounded-2xl p-6 shadow-sm">
              <div class="w-10 h-10 rounded-xl bg-[#BB39B4]/10 flex items-center justify-center shrink-0">
                <span class="text-xl">{emoji}</span>
              </div>
              <div>
                <p class="font-semibold text-[#1A0533] mb-1 text-lg">{title}</p>
                <p class="text-lg text-gray-500 leading-relaxed">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── COURSE SYLLABUS ───────────────────────────────────────────── -->
    <section class="py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3 text-center">Curriculum</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] text-center mb-3">Course Syllabus</h2>
        <p class="text-center text-gray-500 mb-12">16 Lessons · 4 Modules · 3 Projects</p>

        <div class="max-w-2xl mx-auto space-y-3" id="syllabus">
          {[
            {
              module: 'Module 1: Understanding Claude & LLMs',
              lessons: [
                { title: 'What is Claude and how does it actually work?' },
                { title: 'How LLMs think: tokens, context, and memory' },
                { title: 'What Claude is great at (and what it is not)' },
                { title: 'Setting yourself up: accounts, interfaces, and settings' },
              ],
            },
            {
              module: 'Module 2: Prompting Like a Pro',
              lessons: [
                { title: 'The anatomy of a great prompt' },
                { title: 'Giving Claude the right context and role' },
                { title: 'Iterating: how to refine until you get what you need' },
                { title: 'Project: Build your personal prompt library' },
              ],
            },
            {
              module: 'Module 3: Real-World Workflows',
              lessons: [
                { title: 'Using Claude for writing, editing, and feedback' },
                { title: 'Research, summarising, and making sense of long documents' },
                { title: 'Planning, brainstorming, and thinking through hard decisions' },
                { title: 'Project: Automate one task from your real life or work' },
              ],
            },
            {
              module: 'Module 4: Going Further',
              lessons: [
                { title: 'Advanced techniques: few-shot prompting, chaining, and formatting' },
                { title: 'Using Claude with other tools and workflows' },
                { title: 'Staying safe: what to trust, what to verify, and when not to use AI' },
                { title: 'Project: Design your personal AI-powered workflow' },
              ],
            },
          ].map(({ module, lessons }) => (
            <div class="accordion-item border border-gray-200 rounded-2xl overflow-hidden">
              <button
                type="button"
                class="accordion-trigger w-full flex items-center justify-between px-6 py-4 text-left bg-white hover:bg-[#F5F2EB] transition-colors duration-200 cursor-pointer"
                aria-expanded="false"
              >
                <span class="font-semibold text-[#1A0533] text-lg">{module}</span>
                <svg class="accordion-chevron w-5 h-5 text-gray-400 transition-transform duration-300 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <div class="accordion-body">
                <div class="accordion-inner">
                  <ul class="px-6 pb-4 pt-1 space-y-3 border-t border-gray-100">
                    {lessons.map(({ title }) => (
                      <li class="flex items-center justify-between text-lg my-4">
                        <span class="flex items-center gap-2 text-gray-700">
                          <svg class="w-4 h-4 text-gray-300 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polygon points="5 3 19 12 5 21 5 3" />
                          </svg>
                          {title}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    <section class="py-16 md:py-20 bg-[#F5F2EB]">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3 text-center">FAQ</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] text-center mb-4">Frequently Asked Questions</h2>
        <p class="text-center text-gray-500 mb-12 max-w-lg mx-auto">Quick answers to help you decide if this course is right for you.</p>

        <div class="max-w-2xl mx-auto space-y-3" id="faq">
          {[
            {
              q: "Do I need any technical skills to take this course?",
              a: "Not at all. This course was designed from the ground up for complete beginners. If you can type a message and read a response, you have everything you need. No coding, no data science, no prior AI experience required.",
            },
            {
              q: "How long does the course take to complete?",
              a: "The course is fully self-paced, so you set your own timeline. Most students work through all four modules in one to two weeks, spending about 30 to 45 minutes per lesson. You can go faster or slower depending on how much time you have.",
            },
            {
              q: "Is this only about Claude, or will I learn skills that apply to other AI tools?",
              a: "The course uses Claude as its primary example, but the prompting frameworks and workflow strategies you will learn apply to all major LLMs, including ChatGPT, Gemini, and others. The thinking skills transfer everywhere.",
            },
          ].map(({ q, a }) => (
            <div class="accordion-item border border-gray-200 rounded-2xl overflow-hidden bg-white">
              <button
                type="button"
                class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left bg-white hover:bg-[#F5F2EB] transition-colors duration-200 cursor-pointer"
                aria-expanded="false"
              >
                <span class="font-semibold text-lg text-[#1A0533] pr-4">{q}</span>
                <svg class="accordion-chevron w-5 h-5 text-gray-400 transition-transform duration-300 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <div class="accordion-body">
                <div class="accordion-inner">
                  <p class="px-6 pb-5 pt-2 text-gray-600 leading-relaxed border-t border-gray-100 text-lg">{a}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── ENROLL CTA BANNER ──────────────────────────────────────────── -->
    <section id="enroll-form" class="bg-[#1A0533] py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        
        <div class="text-center mb-10 max-w-3xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-3 leading-tight">
            Get Notified When The Course Goes Live
          </h2>
          <p class="text-gray-400 max-w-xl mx-auto text-lg">
            Ready to transform your skills? Sign up with your email.
          </p>
        </div>

        <!-- Countdown Timer (Bottom) -->
        <div class="mb-10 text-center bg-white/5 rounded-2xl p-6 border border-white/10 max-w-md mx-auto">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Course Goes Live In</p>
          <div class="flex items-center justify-center gap-6 countdown-container">
            <div class="flex flex-col">
              <span class="text-4xl md:text-5xl font-bold text-white hours-val">00</span>
              <span class="text-xs text-gray-500 uppercase tracking-wider mt-1">Hours</span>
            </div>
            <span class="text-3xl font-bold text-white/30 pb-4">:</span>
            <div class="flex flex-col">
              <span class="text-4xl md:text-5xl font-bold text-white minutes-val">00</span>
              <span class="text-xs text-gray-500 uppercase tracking-wider mt-1">Mins</span>
            </div>
            <span class="text-3xl font-bold text-white/30 pb-4">:</span>
            <div class="flex flex-col">
              <span class="text-4xl md:text-5xl font-bold text-white seconds-val">00</span>
              <span class="text-xs text-gray-500 uppercase tracking-wider mt-1">Secs</span>
            </div>
          </div>
        </div>

        <!-- Waitlist Form Card -->
        <div class="max-w-md mx-auto">
          <!-- Success State -->
          <div id="waitlist-success" class="hidden bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-center">
            <div class="w-12 h-12 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">You're on the list!</h3>
            <p class="text-gray-400 text-sm">We'll send you an email as soon as the course is live.</p>
          </div>

          <!-- Form Element -->
          <form id="waitlist-form" novalidate class="bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-6 md:p-8">
            <div class="mb-4">
              <label for="waitlist-email" class="sr-only">Email Address</label>
              <input
                type="email"
                id="waitlist-email"
                name="email"
                placeholder="Enter your email address"
                required
                class="w-full bg-white/10 rounded-xl px-5 py-4 text-white placeholder-gray-400 border border-transparent focus:outline-none focus:ring-2 focus:ring-[#BB39B4] focus:border-[#BB39B4] transition-all duration-200"
              />
              <p id="waitlist-email-error" class="text-red-400 text-xs mt-2 hidden text-left">Please enter a valid email address.</p>
            </div>
            <button
              type="submit"
              id="waitlist-submit-btn"
              class="w-full bg-[#BB39B4] hover:bg-[#a832a1] text-white font-bold text-base rounded-xl py-4 transition-colors duration-200 cursor-pointer"
            >
              Access the Course
            </button>
          </form>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* Accordion: grid row height animation (same pattern as FAQ component) */
  .accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease;
  }

  .accordion-body.is-open {
    grid-template-rows: 1fr;
  }

  .accordion-inner {
    overflow: hidden;
  }

  .accordion-chevron.is-open {
    transform: rotate(180deg);
  }
</style>

<script>
  import PocketBase from 'pocketbase';

  declare global {
    interface Window { posthog?: any; }
  }

  function initAccordions() {
    document.querySelectorAll('.accordion-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.accordion-item')!;
        const body = item.querySelector('.accordion-body')!;
        const chevron = trigger.querySelector('.accordion-chevron')!;
        const isOpen = body.classList.contains('is-open');

        body.classList.toggle('is-open', !isOpen);
        chevron.classList.toggle('is-open', !isOpen);
        trigger.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  }

  function initWaitlist() {
    const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
    const successMsg = document.getElementById('waitlist-success');
    if (!form || !successMsg) return;

    const emailInput = form.querySelector('#waitlist-email') as HTMLInputElement;
    const emailError = document.getElementById('waitlist-email-error')!;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function validateEmail(): boolean {
      const valid = emailRegex.test(emailInput.value.trim());
      emailError.classList.toggle('hidden', valid || emailInput.value.trim() === '');
      return valid;
    }

    emailInput.addEventListener('blur', validateEmail);

    const pb = new PocketBase(import.meta.env.PUBLIC_POCKETBASE_URL);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validateEmail()) {
        emailInput.focus();
        return;
      }

      const submitBtn = document.getElementById('waitlist-submit-btn') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      const formData = new FormData(form);
      const data = {
        email: formData.get('email') as string,
      };

      try {
        await pb.collection('Waitlist_Form').create(data);

        window.posthog?.capture('waitlist_joined', {
          course: 'Claude for Beginners'
        });

        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      } catch (err) {
        window.posthog?.captureException(err);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Access the Course';
        alert('Something went wrong. Please try again or contact support.');
      }
    });
  }

  function initCountdown() {
    const containers = document.querySelectorAll('.countdown-container');
    if (!containers.length) return;

    // You can edit this date to whatever target time you want the launch to be.
    // Use the format: 'YYYY-MM-DDTHH:mm:ss±HH:mm' for timezone safety.
    const TARGET_DATE = new Date('2026-04-02T20:05:00+01:00').getTime();

    function updateCounters() {
      const now = new Date().getTime();
      const distance = TARGET_DATE - now;

      if (distance <= 0) {
        // Countdown finished
        containers.forEach(container => {
          (container.querySelector('.hours-val') as HTMLElement).textContent = '00';
          (container.querySelector('.minutes-val') as HTMLElement).textContent = '00';
          (container.querySelector('.seconds-val') as HTMLElement).textContent = '00';
        });
        return;
      }

      // Calculate time components (handles > 24 hours easily)
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)) + Math.floor(distance / (1000 * 60 * 60 * 24)) * 24;
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      const hFormatted = hours.toString().padStart(2, '0');
      const mFormatted = minutes.toString().padStart(2, '0');
      const sFormatted = seconds.toString().padStart(2, '0');

      containers.forEach(container => {
        (container.querySelector('.hours-val') as HTMLElement).textContent = hFormatted;
        (container.querySelector('.minutes-val') as HTMLElement).textContent = mFormatted;
        (container.querySelector('.seconds-val') as HTMLElement).textContent = sFormatted;
      });
    }

    // Run first update and then run set interval
    updateCounters();
    setInterval(updateCounters, 1000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initAccordions();
      initWaitlist();
      initCountdown();
    });
  } else {
    initAccordions();
    initWaitlist();
    initCountdown();
  }
</script>
