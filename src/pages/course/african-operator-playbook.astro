---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const course = {
  title: 'The African Operator Playbook',
  description: 'Most business education was built for Western markets. This course was built for Africa. Learn how to operate, scale, and lead businesses across the continent, from distribution and logistics to managing teams, raising capital, and navigating complex environments.',
  price: 750000,
  originalPrice: 800000,
  startDate: 'Monday, April 6',
  duration: '8 Weeks',
  level: 'Intermediate',
  format: 'Cohort Based',
  rating: 4.9,
  thumbnail: '/images/babajide-hs.png',
  instructorPhoto: '/images/babajide.jpg',
};
---

<Layout
  title="The African Operator Playbook - UniversityX"
  description="Learn how to operate, scale, and lead businesses across Africa. A live 8-week cohort with Babajide Duroshola, GM of M-KOPA Nigeria."
>
  <!-- Navbar -->
  <Navbar />

  <main class="bg-white">

    <!-- ── HERO SECTION ─────────────────────────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24 pt-10 pb-0">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <a href="/#browse-courses" class="hover:text-[#BB39B4] transition-colors">All Courses</a>
        <svg class="w-3.5 h-3.5 text-[#BB39B4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6" />
        </svg>
        <span class="text-[#1A0533] font-medium">The African Operator Playbook</span>
      </nav>

      <!-- Two-column layout: content left, sidebar right -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-12 xl:gap-16 items-start">

        <!-- ── LEFT COLUMN ───────────────────────────────────────────── -->
        <div>
          <!-- Title -->
          <h1 class="text-3xl md:text-4xl font-extrabold text-[#1A0533] leading-tight mb-5">
            The African Operator Playbook:
            <em class="font-['Playfair_Display',serif] font-bold"> Build, Scale, and Lead High-Growth Companies in Africa</em>
          </h1>

          <!-- Description -->
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Most business education was built for Western markets. This course was built for Africa.
            Learn how real operators run businesses across the continent, from navigating infrastructure
            gaps and managing distributed teams, to raising capital and building customer trust in
            low-trust environments.
          </p>

          <!-- What you'll learn -->
          <ul class="space-y-2.5 mb-8 text-lg">
            {[
              'How to build operations that work in African markets, despite infrastructure, logistics, and payment challenges',
              'Frameworks for managing teams, vendors, and stakeholders across multiple African cities',
              'How to raise capital, manage cash flow, and structure deals that actually close',
              'Real-world case studies from companies operating at scale across Nigeria and East Africa',
            ].map((item) => (
              <li class="flex items-start gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#BB39B4] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <!-- Metadata chips -->
          <div class="flex flex-wrap gap-3 mb-8">
            {[
              { icon: 'clock', label: '8 Weeks' },
              { icon: 'bar-chart', label: 'Intermediate' },
              { icon: 'users', label: 'Cohort Based' },
            ].map(({ label }) => (
              <span class="inline-flex items-center gap-2 bg-[#F5F2EB] text-[#1A0533] text-base font-medium px-4 py-2 rounded-full">
                {label}
              </span>
            ))}
          </div>

          <!-- Instructor strip -->
          <div class="border-t border-gray-100 pt-6">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Instructor</p>
            <div class="flex items-center gap-4">
              <img
                src={course.instructorPhoto}
                alt="Babajide Duroshola"
                class="w-18 h-18 rounded-full object-cover object-top shrink-0"
                loading="eager"
              />
              <div>
                <p class="font-semibold text-[#1A0533] text-lg">Babajide Duroshola</p>
                <p class="text-base text-gray-500">General Manager, M-KOPA Nigeria. Operator across tech, banking, consulting & startups</p>
              </div>
            </div>

            <!-- Companies worked with -->
            <div class="mt-5">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Have operated across</p>
              <div class="flex items-center flex-wrap gap-5">
                <img src="/images/mkopa-logo.png" alt="Mkopa" class="h-8" loading="lazy" />
                <img src="/images/safeboda-logo.png" alt="SafeBoda" class="h-6" loading="lazy" />
                <img src="/images/logo-andela.svg" alt="Andela" class="h-8" loading="lazy" />
              </div>
            </div>
          </div>
        </div>

        <!-- ── RIGHT COLUMN: STICKY SIDEBAR ─────────────────────────── -->
        <aside class="lg:sticky lg:top-6">
          <div class="rounded-2xl border border-gray-200 shadow-lg overflow-hidden">
            <!-- Course thumbnail -->
            <img
              src={course.thumbnail}
