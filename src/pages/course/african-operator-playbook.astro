                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                Starts {course.startDate}
              </div>

              <!-- Enroll CTA -->
              <a
                id="enroll"
                href="#enroll-form"
                class="block w-full text-center bg-[#BB39B4] hover:bg-[#a832a1] text-white font-semibold px-8 py-4 rounded-lg transition-colors duration-200 text-base mt-10"
              >
                Enroll Now
              </a>

              <!-- UniversityX Approved -->
              <!-- <div class="flex items-start gap-3 bg-[#F5F2EB] rounded-xl p-4 mt-2">
                <img src="/images/universityx-svg.svg" alt="" class="h-6 w-auto shrink-0 mt-0.5" loading="lazy" />
                <div>
                  <p class="text-sm font-semibold text-[#1A0533]">UniversityX Approved</p>
                  <p class="text-xs text-gray-500 mt-0.5 leading-snug">Reviewed for quality, relevance, and real-world impact.</p>
                </div>
              </div> -->
            </div>
          </div>
        </aside>

      </div>
    </section>


    <!-- ── COURSE OVERVIEW ───────────────────────────────────────────── -->
    <section class="bg-[#F5F2EB] mt-16 py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24 max-w-3xl">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3">Course Overview</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] leading-tight mb-6">
          Stop applying Western playbooks to African problems.
