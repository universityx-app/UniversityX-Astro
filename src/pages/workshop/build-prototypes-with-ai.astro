    <section id="enroll-form" class="bg-[#1A0533] py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <div class="text-center mb-10 max-w-2xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-3 leading-tight">
            Ready to build your prototype?
          </h2>
          <p class="text-gray-400 max-w-lg mx-auto">
            Register free. We'll send you the event link and an AI tools setup checklist before the day.
          </p>
        </div>

        <!-- Success State -->
        <div id="register-success" class="hidden max-w-md mx-auto bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10 p-8 text-center">
          <div class="w-12 h-12 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">You're registered!</h3>
          <p class="text-gray-400 text-sm">We'll send you the event link and setup checklist closer to the date.</p>
        </div>

        <!-- Form -->
        <form id="register-form" novalidate class="max-w-md mx-auto bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-6 md:p-8">
          <div class="mb-4">
            <label for="register-email" class="sr-only">Email Address</label>
            <input
              type="email"
              id="register-email"
              name="email"
              placeholder="Enter your email address"
