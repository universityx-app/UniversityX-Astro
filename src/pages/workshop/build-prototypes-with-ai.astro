      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
        <p class="text-xs font-semibold text-[#BB39B4] uppercase tracking-widest mb-3 text-center">Who This Is For</p>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1A0533] text-center mb-12">This Workshop Is For You If...</h2>
