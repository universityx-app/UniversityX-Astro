---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

const workshops = [
  {
    title: 'How to Build Prototypes with AI',
    thumbnail: '/images/afolabi-workshop-cover.png',
    rating: 5.0,
    startDate: 'May 9',
    duration: 'Workshop',
    level: 'Beginner',
    url: '/workshop/build-prototypes-with-ai',
    instructors: [
      {
        name: 'Afolabi Sokeye',
        bio: 'Product Manager who builds things with AI, not just talks about it. He has shipped products used by 8,000+ users at Trakka, led product development at TechWings Global and Riverscope Technologies',
      },
    ],
  },
];
---

<Layout
  title="Workshops — UniversityX"
  description="Join live, focused workshops on AI, product, design and more. Learn from practitioners in a single day."
>
  <Navbar />

  <section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">

      <!-- Header -->
      <div class="mb-14">
        <h1 class="text-3xl md:text-4xl font-extrabold leading-tight text-[#1A0533]">
          Workshops: {' '}
          <em class="font-['Playfair_Display',serif] font-bold">Learn in a Day.</em>
        </h1>
        <p class="mt-4 text-lg text-gray-500 max-w-xl leading-relaxed">
          Focused, live sessions with practitioners. No fluff, just hands-on learning you can apply immediately.
        </p>
      </div>

      <!-- Workshop grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {workshops.map((workshop) => (
          <a
            href={workshop.url}
            class="block bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300"
            aria-label={`View workshop: ${workshop.title}`}
          >
            <!-- Thumbnail -->
            <Image
              src={workshop.thumbnail}
              alt={workshop.title}
              width={600}
              height={338}
              class="w-full aspect-video object-cover"
              loading="eager"
            />

            <!-- Card body -->
            <div class="p-5">
              <h2 class="text-lg font-bold text-[#1A0533] leading-snug mb-3">
                {workshop.title}
              </h2>

              <!-- Metadata row -->
              <div class="flex items-center flex-wrap gap-x-1.5 gap-y-1 text-base text-gray-400 mb-4">
                <span class="flex items-center gap-0.5">
                  <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  {workshop.rating}
                </span>
                <img src="/images/dot.svg" class="w-[0.3rem] mx-1" alt="" loading="eager" />
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {workshop.duration}
                </span>
                <img src="/images/dot.svg" class="w-[0.3rem] mx-1" alt="" loading="eager" />
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="14" width="4" height="6" />
                    <rect x="10" y="8" width="4" height="12" />
                    <rect x="18" y="4" width="4" height="16" />
                  </svg>
                  {workshop.level}
                </span>
              </div>

              <hr class="border-gray-300 border-t my-4" />

              <!-- Instructors -->
              <div class="space-y-1.5">
                {workshop.instructors.map((instructor) => (
                  <p class="text-base leading-snug">
                    <span class="font-semibold text-[#1A0533]">{instructor.name}</span>
                    <span class="text-gray-400 ml-1.5">{instructor.bio}</span>
                  </p>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <Footer />
</Layout>
