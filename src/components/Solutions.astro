---
const solutions = [
  {
    title: 'For Businesses',
    description:
      'Stop settling for generic courses with zero completion rates. Upskill your team with a mix of live cohorts and self-paced tracks designed for immediate workplace impact.',
    link: '/businesses',
    icon: 'briefcase',
  },
  {
    title: 'For Universities',
    description:
      'Bridge the gap between theory and industry. Partner with UniversityX to offer students practical skill tracks that complement their degree and ensure they are day-one ready.',
    link: '/universities',
    icon: 'building',
  },
  {
    title: 'Teach on UniversityX',
    description:
      "Monetize Your Expertise. Host live cohorts, or launch self-paced courses. Bring your course or join us as an instructor. We build the platform, you share your knowledge.",
    link: '/teach',
    icon: 'lightbulb',
  },
];
---

<section class="bg-[#F5F2EB] bg-[url('/images/bg-marble.png')] bg-cover bg-center py-20 md:py-28" id="solutions">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 xl:px-24">
    <!-- Header -->
    <div class="mb-16">
      <h2
        class="text-3xl md:text-4xl font-extrabold text-[#1A0533] leading-tight"
      >
        Building the Future of Work
        <!-- <br />
        <em class="font-['Playfair_Display',serif] font-bold">
          
        </em> -->
      </h2>
      <p class="text-lg md:text-xl mt-4 text-gray-600 max-w-2xl">
        Whether you're an organization seeking to upskill your workforce, an academic institution aiming to enhance student readiness, or an expert ready to share your knowledge, UniversityX offers the platform and programs to achieve your goals.
      </p>
    </div>

    <!-- Card Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {
        solutions.map((card) => (
          <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg transition-shadow duration-300 flex flex-col">
            {/* Icon */}
            {/* <div class="w-14 h-14 rounded-xl bg-[#F5F2EB] flex items-center justify-center mb-6"> */}
              {card.icon === 'briefcase' && (
                <img 
                src="/images/briefcase.png"
                alt="briefcase"
                class="w-16 mb-5"
                />
              )}
              {card.icon === 'building' && (
                <img 
                src="/images/graduation-hat.png"
                alt="briefcase"
                class="w-18 mb-3"
                />
              )}
              {card.icon === 'lightbulb' && (
                <img 
                src="/images/teach-icon.png"
                alt="briefcase"
                class="w-16 mb-5"
                />
              )}

            {/* Title */}
            <h3 class="text-xl font-bold text-[#1A0533] mb-3">{card.title}</h3>

            {/* Description */}
            <p class="text-gray-600 text-lg leading-relaxed mb-6 flex-1">
              {card.description}
            </p>

            {/* Learn More Link */}
            <a
              href={card.link}
              class="inline-flex items-center gap-2 text-[#BB39B4] font-semibold hover:underline"
            >
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M12 8l4 4-4 4" />
                <path d="M8 12h8" />
              </svg>
              Learn More
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
